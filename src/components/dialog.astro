<sl-dialog label="Christmas & New Year Hours" class="dialog-overview" style="--width: 60vw;" open>
  <div class="announcement-dialog">
    <h1>Christmas Opening Hours 🎄</h1>
    <p class="subtitle">Wishing you a warm and joyful festive season</p>

    <h2>Holiday Trading Hours</h2>

    <div class="hours-list">
      <p><strong>Christmas Eve</strong> — 24th Dec: <strong>7AM – 4PM</strong></p>
      <p><strong>Christmas Day</strong> — 25th Dec: <strong>7AM – 3PM</strong></p>
      <p><strong>Boxing Day</strong> — 26th Dec: <strong>7AM – 3PM</strong></p>
      <p><strong>Saturday</strong> — 27th Dec: <strong>9AM – 5PM</strong></p>
      <p><strong>Sunday</strong> — 28th Dec: <strong>CLOSED</strong></p>
      <p><strong>Monday</strong> — 29th Dec: <strong>7AM – 4PM</strong></p>
      <p><strong>Tuesday</strong> — 30th Dec: <strong>7AM – 4PM</strong></p>
      <p><strong>New Year’s Eve</strong> — 31st Dec: <strong>7AM – 4PM</strong></p>
      <p><strong>New Year’s Day</strong> — 1st Jan: <strong>CLOSED</strong></p>
      <p><strong>Friday</strong> — 2nd Jan: <strong>CLOSED</strong></p>
      <p><strong>Saturday</strong> — 3rd Jan: <strong>CLOSED</strong></p>
      <p><strong>Sunday</strong> — 4th Jan: <strong>CLOSED</strong></p>
    </div>

    <p class="message">
      Thank you for supporting <strong>BAKE ON</strong> throughout the year.
      We look forward to welcoming you during the festive season! ✨
    </p>

    <p class="signature">
      With love,<br />
      <strong>The BAKE ON Team</strong>
    </p>
  </div>

  <sl-button slot="footer" variant="primary">Close</sl-button>
</sl-dialog>

<script>
  const dialog = document.querySelector(".dialog-overview");
  const closeButton = dialog?.querySelector('sl-button[slot="footer"]');

  closeButton?.addEventListener("click", () => dialog?.hide());
</script>
