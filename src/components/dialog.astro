<sl-dialog class="dialog-overview" style="--width: 65vw;" open no-header>
  <div class="announcement-dialog">
    <h1>Christmas Opening Hours 🎄</h1>
    <p class="subtitle">Wishing you a warm and joyful festive season</p>

    <h2>Holiday Hours</h2>

    <div class="hours-list">
      <div class="row">
        <span>Christmas Eve</span><span>24</span><strong>7AM – 4PM</strong>
      </div>
      <div class="row">
        <span>Christmas Day</span><span>25</span><strong>7AM – 3PM</strong>
      </div>
      <div class="row">
        <span>Boxing Day</span><span>26</span><strong>7AM – 3PM</strong>
      </div>
      <div class="row">
        <span>Saturday</span><span>27</span><strong>9AM – 5PM</strong>
      </div>
      <div class="row closed">
        <span>Sunday</span><span>28</span><strong>CLOSED</strong>
      </div>
      <div class="row">
        <span>Monday</span><span>29</span><strong>7AM – 4PM</strong>
      </div>
      <div class="row">
        <span>Tuesday</span><span>30</span><strong>7AM – 4PM</strong>
      </div>
      <div class="row">
        <span>New Year’s Eve</span><span>31</span><strong>7AM – 4PM</strong>
      </div>
      <div class="row closed">
        <span>New Year’s Day</span><span>1</span><strong>CLOSED</strong>
      </div>
      <div class="row closed">
        <span>Friday</span><span>2</span><strong>CLOSED</strong>
      </div>
      <div class="row closed">
        <span>Saturday</span><span>3</span><strong>CLOSED</strong>
      </div>
      <div class="row closed">
        <span>Sunday</span><span>4</span><strong>CLOSED</strong>
      </div>
    </div>

    <p class="message">
      Thank you for supporting <strong>BAKE ON</strong> throughout the year.
      We look forward to welcoming you during the festive season! ✨
    </p>

    <p>
      With love,<br />
      <strong>The BAKE ON Team</strong>
    </p>
  </div>

  <sl-button slot="footer" variant="primary">Close</sl-button>
</sl-dialog>

<script>
  const dialog = document.querySelector(".dialog-overview");
  const closeButton = dialog?.querySelector('sl-button[slot="footer"]');

  closeButton?.addEventListener("click", () => dialog?.hide());
</script>
