<sl-dialog class="dialog-overview" style="--width: 65vw;" open no-header>
  <div class="announcement-dialog">
    <h1>Easter Holiday Hours 🐣</h1>
    <p class="subtitle">Wishing you a wonderful Easter weekend</p>

    <h2>Holiday Hours</h2>

    <div class="hours-list">
      <div class="row">
        <span>Good Friday</span><span>3</span><strong>7AM – 4PM</strong>
      </div>
      <div class="row">
        <span>Saturday</span><span>4</span><strong>9AM – 5PM</strong>
      </div>
      <div class="row closed">
        <span>Sunday</span><span>5</span><strong>CLOSED</strong>
      </div>
      <div class="row closed">
        <span>Easter Monday</span><span>6</span><strong>CLOSED</strong>
      </div>
    </div>

    <p class="message">
      Thank you for supporting <strong>BAKE ON</strong> throughout the year.
      We look forward to welcoming you over the Easter weekend! 🌸
    </p>

    <p>
      With love,<br />
      <strong>The BAKE ON Team</strong>
    </p>
  </div>

  <sl-button slot="footer" variant="primary">Close</sl-button>
</sl-dialog>

<script>
  const dialog = document.querySelector(".dialog-overview");
  const closeButton = dialog?.querySelector('sl-button[slot="footer"]');

  closeButton?.addEventListener("click", () => dialog?.hide());
</script>